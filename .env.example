# PostgreSQL (Supabase: Project Settings → Database)
#
# Local dev: "Direct connection" URI (db.*.supabase.co:5432) is fine.
#
# Vercel / serverless: use "Connection pooling" → Transaction mode (port 6543,
# host like aws-0-REGION.pooler.supabase.com). Direct db.*:5432 often fails from
# Vercel with "Can't reach database server". Append ?pgbouncer=true (and keep
# sslmode=require if your dashboard includes it).
#
# Pooled (e.g. transaction mode, port 6543) — used by the app / Prisma `url`
# DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require"
#
# Direct — used by Prisma `directUrl` for migrations / db push (often db.*.supabase.co:5432 from Supabase dashboard)
# DIRECT_URL="postgresql://postgres:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres?sslmode=require"
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true&sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres?sslmode=require"

# Auth.js v5 — generate with: openssl rand -base64 32
AUTH_SECRET=""

# Local: http://localhost:3000
# Vercel: optional for default *.vercel.app (app uses VERCEL_URL). Set for a custom domain.
AUTH_URL="http://localhost:3000"

# Local `next dev` only — shared password for email sign-in (never used on Vercel production).
AUTH_DEV_PASSWORD="dev"

# Google OAuth — Authorized redirect URI must be exactly:
#   {AUTH_URL or NEXTAUTH_URL or https://YOUR_VERCEL_HOST}/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Legacy aliases (optional if AUTH_* are set)
# NEXTAUTH_SECRET=""
# NEXTAUTH_URL=""
